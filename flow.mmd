%%{init: {'theme': 'default', 'themeVariables': {'fontFamily': 'Noto Sans CJK SC, sans-serif', 'fontSize': '14px'}}}%%
flowchart TB
    %% ===== 阶段一：买家开户 & 绑卡 =====
    subgraph A["🏦 阶段一：买家开户 & 绑卡"]
        direction TB
        A1([买家发起开户申请])
        A2["法人扫脸（交通银行侧）\n唯一开户方式，不支持绿通"]
        A3{扫脸通过?}
        A4[扫脸失败\n引导重试]
        A5[买家会员子账簿开立成功\n交通银行三级账户体系]
        A6[买家发起绑卡]
        A7{绑卡类型?}
        A8[同名账户绑定\n不需去银行]
        A9["非同名绑定\n个体户法人卡\n需去交通银行绑定"]
        A10[/"限制：个人卡最多4张\n绑定24小时后才可充值"/]

        A1 --> A2 --> A3
        A3 -->|否| A4 --> A2
        A3 -->|是| A5 --> A6 --> A7
        A7 -->|同名| A8 --> A10
        A7 -->|非同名| A9 --> A10
    end

    %% ===== 阶段二：充值入金 =====
    subgraph B["💰 阶段二：充值入金"]
        direction TB
        B1[买家发起充值]
        B2{充值来源?}
        B3[同名账户充值]
        B4["绑定卡充值\n含个体户法人同名户"]
        B5["白名单入金\n交通银行分行签约维护"]
        B6[[风控问询\n充值维度]]
        B7[/"问询项：\n付款人身份证或营业执照 → 反洗钱\n付款账号 → 警情卡检查\nwxid或付款卡 → 黑名单/高风险\n企业社会信用代码 → 风险评级\n操作人身份证 → 反洗钱"/]
        B8["风控通过\n资金入账\n买家会员子账簿（交通银行）"]
        B9[风控拦截\n对客提示或退款]

        B1 --> B2
        B2 -->|同名| B3 --> B6
        B2 -->|绑定卡| B4 --> B6
        B2 -->|白名单| B5 --> B8
        B6 -. 问询项 .-> B7
        B6 -->|通过| B8
        B6 -->|拦截| B9
    end

    %% ===== 阶段三：余额支付 =====
    subgraph C["💳 阶段三：余额支付（买家付款）"]
        direction TB
        C1["买家在收银台选择\n微资金余额付款"]
        C2{"单笔金额?\n（交通银行免密额度）"}
        C3["银行免密\n直接发起划转"]
        C4[收银台触发一次鉴权]
        C5["鉴权通过后自动拆单\n每笔不超过5万元\n例：15.2万 → 5+5+5+0.2万（共4笔）"]
        C6["逐笔发起划转\n买家账簿 → 品牌方账簿\n（交通银行登记簿划转）"]
        C7[[交易风控问询\n同微企付交易逻辑]]
        C8["付款成功\n公众号通知买家"]
        C9[付款失败\n对客提示]

        C1 --> C2
        C2 -->|"单笔 ≤ 5万元"| C3 --> C6
        C2 -->|"单笔 > 5万元"| C4 --> C5 --> C6
        C6 --> C7
        C7 -->|通过| C8
        C7 -->|拦截| C9
    end

    %% ===== 阶段四：退款 =====
    subgraph D["↩️ 阶段四：退款"]
        direction TB
        D1[商户发起退款]
        D2["调用交通银行登记簿退款接口\n关联原单，原路退款"]
        D3["退款成功\n资金退回买家账簿\n公众号通知买家"]

        D1 --> D2 --> D3
    end

    %% ===== 阶段五：提现 =====
    subgraph E["🏧 阶段五：余额提现"]
        direction TB
        E1[买家发起提现]
        E2{提现模式?}
        E3["手动提现\n操作人主动发起"]
        E4["自动提现\n收银资金，次日10点自动执行\n充值/退款资金不生效"]
        E5[[风控问询\n提现维度]]
        E6[/"问询项：\n提现卡 → 风控提现策略\n营业执照/法人/受益人/付款人身份证 → 反洗钱\n提现卡/交通银行开户行 → 反洗钱甲方名单"/]
        E7["提现成功\n到账绑定的交通银行账户\n公众号通知买家"]
        E8[风控拦截\n对客提示]

        E1 --> E2
        E2 -->|手动| E3 --> E5
        E2 -->|自动| E4 --> E5
        E5 -. 问询项 .-> E6
        E5 -->|通过| E7
        E5 -->|拦截| E8
    end

    %% ===== 阶段间连接 =====
    A10 --> B1
    B8 --> C1
    C8 -->|退款场景| D1
    C8 -->|提现场景| E1

    %% ===== 样式 =====
    classDef start fill:#BBDEFB,stroke:#1565C0,color:#000
    classDef process fill:#E3F2FD,stroke:#1565C0,color:#000
    classDef decision fill:#FFF9C4,stroke:#F57F17,color:#000
    classDef success fill:#C8E6C9,stroke:#2E7D32,color:#000
    classDef fail fill:#FFCCBC,stroke:#BF360C,color:#000
    classDef risk fill:#FFF3E0,stroke:#E65100,color:#000,stroke-dasharray:5 5
    classDef note fill:#FFFDE7,stroke:#F9A825,color:#555

    class A1 start
    class A2,A5,A6,A8,A9,B3,B4,B5,C1,C3,C4,C5,C6,D1,D2,E1,E3,E4 process
    class A3,A7,B2,C2,E2 decision
    class B8,C8,D3,E7 success
    class A4,B9,C9,E8 fail
    class B6,C7,E5 risk
    class A10,B7,E6 note
